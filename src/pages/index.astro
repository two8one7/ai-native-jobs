---
import FilterBar from '../components/FilterBar.astro';
import Base from '../layouts/Base.astro';
import { countActiveListings, getRecentListings } from '../lib/db';
import { formatComp, formatLocation, formatPostedAt, getCompanyPath, getJobPath, readFilters } from '../lib/jobs';

export const prerender = false;

const PAGE_SIZE = 50;
const filters = readFilters(Astro.url.searchParams);

const rawPage = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const total = await countActiveListings(filters);
const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
const page = Number.isFinite(rawPage) && rawPage >= 1 ? Math.min(rawPage, totalPages) : 1;
const offset = (page - 1) * PAGE_SIZE;
const listings = await getRecentListings(filters, PAGE_SIZE, offset);

const buildPageHref = (target: number): string => {
  const params = new URLSearchParams(Astro.url.searchParams);
  if (target <= 1) {
    params.delete('page');
  } else {
    params.set('page', String(target));
  }
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
};

const rangeStart = total === 0 ? 0 : offset + 1;
const rangeEnd = Math.min(offset + listings.length, total);
---

<Base title="AI Native Jobs" description="Fresh AI-native roles from serious companies.">
  <section class="mb-8">
    <h1 class="font-serif text-4xl leading-none tracking-tight text-ink sm:text-5xl">AI-native jobs.</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-black/65">
      High-signal listings for infrastructure, research, robotics, and ops teams shipping with models in the loop.
    </p>
  </section>

  <FilterBar filters={filters} currentSearch={Astro.url.searchParams} />

  {listings.length === 0 ? (
    <section class="border border-dashed border-black/15 px-4 py-8 text-sm text-black/65">
      <p>
        No listings match. <a href="/" class="text-accent underline underline-offset-2">Clear filters</a>
      </p>
    </section>
  ) : (
    <section class="border-t border-black/10">
      {listings.map((listing) => (
        <article class="border-b border-black/10 py-3">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
            <div class="flex flex-col gap-1 sm:flex-row sm:flex-wrap sm:items-baseline sm:gap-x-2 sm:gap-y-1">
              <h2 class="font-serif text-xl leading-tight text-ink">
                <a href={getJobPath(listing)} class="hover:text-accent">{listing.title}</a>
              </h2>
              <a href={getCompanyPath(listing.company_slug)} class="text-sm text-black/70 hover:text-accent">
                {listing.company_name}
              </a>
              <div class="text-xs text-black/55 sm:hidden">
                <span>{formatLocation(listing)}</span>
                <span class="mx-1">·</span>
                <span>{formatComp(listing.comp_min, listing.comp_max, listing.comp_currency)}</span>
              </div>
            </div>
            <div class="mt-1 hidden flex-wrap items-center gap-x-2 gap-y-1 text-xs text-black/55 sm:flex sm:justify-end">
              <span>{listing.company_name}</span>
              <span>·</span>
              <span>{formatLocation(listing)}</span>
              <span>·</span>
              <span>{formatComp(listing.comp_min, listing.comp_max, listing.comp_currency)}</span>
              <span>·</span>
              <time datetime={new Date(listing.posted_at).toISOString()}>{formatPostedAt(listing.posted_at)}</time>
            </div>
            <div class="mt-1 text-xs text-black/55 sm:hidden">
              <time datetime={new Date(listing.posted_at).toISOString()}>{formatPostedAt(listing.posted_at)}</time>
            </div>
          </div>
        </article>
      ))}
    </section>
    <nav class="mt-6 flex items-center justify-between text-xs text-black/55" aria-label="Pagination">
      <p>
        {rangeStart}–{rangeEnd} of {total}
      </p>
      <div class="flex items-center gap-3">
        {page > 1 ? (
          <a href={buildPageHref(page - 1)} class="border border-black/15 px-2 py-1 text-ink hover:text-accent">
            ← Prev
          </a>
        ) : (
          <span class="border border-black/10 px-2 py-1 text-black/30">← Prev</span>
        )}
        <span>
          Page {page} of {totalPages}
        </span>
        {page < totalPages ? (
          <a href={buildPageHref(page + 1)} class="border border-black/15 px-2 py-1 text-ink hover:text-accent">
            Next →
          </a>
        ) : (
          <span class="border border-black/10 px-2 py-1 text-black/30">Next →</span>
        )}
      </div>
    </nav>
  )}
</Base>
