---
import Base from '../../../layouts/Base.astro';
import { getAllActiveListings, type ListingListRow } from '../../../lib/db';
import { formatComp, formatLocation, formatPostedAt, getCompanyPath, getRoleSlug, parseAiStack } from '../../../lib/jobs';
import { buildJobPostingJsonLd } from '../../../lib/seo';

export async function getStaticPaths() {
  const listings = await getAllActiveListings();

  return listings.map((listing) => ({
    params: {
      company: listing.company_slug,
      role: getRoleSlug(listing),
    },
    props: {
      listing,
    },
  }));
}

const { listing } = Astro.props as { listing: ListingListRow };
const stack = parseAiStack(listing.ai_stack);
const jobPostingJsonLd = buildJobPostingJsonLd(listing);
---

<Base title={`${listing.title} · ${listing.company_name}`} description={listing.company_description ?? listing.title}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jobPostingJsonLd)} />
  <article class="mx-auto max-w-3xl">
    <a href="/" class="text-xs uppercase tracking-wide text-black/55 hover:text-accent">All jobs</a>
    <header class="mt-4 border-b border-black/10 pb-6">
      <p class="text-sm text-black/60">
        <a href={getCompanyPath(listing.company_slug)} class="hover:text-accent">{listing.company_name}</a>
      </p>
      <h1 class="mt-2 font-serif text-4xl leading-tight text-ink">{listing.title}</h1>
      <div class="mt-4 flex flex-wrap gap-2 text-xs text-black/60">
        <span class="border border-black/10 px-2 py-1">{formatLocation(listing)}</span>
        <span class="border border-black/10 px-2 py-1">{formatComp(listing.comp_min, listing.comp_max, listing.comp_currency)}</span>
        <time class="border border-black/10 px-2 py-1" datetime={new Date(listing.posted_at).toISOString()}>
          Posted {formatPostedAt(listing.posted_at)}
        </time>
        {listing.ai_specialty && <span class="border border-black/10 px-2 py-1 uppercase">{listing.ai_specialty}</span>}
      </div>
      <a
        href={listing.apply_url}
        target="_blank"
        rel="noopener"
        class="mt-6 inline-flex border border-ink px-4 py-2 text-sm uppercase tracking-wide hover:bg-ink hover:text-paper"
      >
        Apply
      </a>
    </header>

    {stack.length > 0 && (
      <section class="mt-6">
        <h2 class="text-xs uppercase tracking-wide text-black/55">AI stack</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {stack.map((item) => (
            <span class="border border-black/10 px-2 py-1 text-xs text-black/70">{item}</span>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 font-serif text-lg leading-8 text-black/80 [&_a]:text-accent [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-semibold [&_h3]:mt-6 [&_h3]:text-xl [&_li]:ml-5 [&_li]:list-disc [&_p]:mb-4 [&_ul]:mb-4">
      <div set:html={listing.description_html} />
    </section>
  </article>
</Base>
