{
  "name": "ai-native-jobs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun run dist/server/entry.mjs",
    "migrate": "bun run src/db/migrate.ts",
    "db:smoke": "bun run src/db/smoke.ts",
    "scrape:yc": "bun run src/bin/scrape-yc.ts",
    "probe:careers": "bun run src/bin/probe-careers.ts",
    "probe:careers:headless": "bun run src/bin/probe-careers-headless.ts",
    "scrape:ats": "bun run src/bin/scrape-ats.ts",
    "scrape:ats:all": "bun run src/bin/scrape-ats.ts all",
    "backfill:descriptions": "bun run src/bin/backfill-descriptions.ts",
    "fix:expires-at-units": "bun run src/bin/fix-expires-at-units.ts",
    "sweep:expired": "bun run src/bin/sweep-expired.ts",
    "typecheck": "astro check"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^9.5.0",
    "@astrojs/sitemap": "^3.6.0",
    "@tailwindcss/vite": "^4.1.12",
    "astro": "^5.13.5",
    "bun-types": "^1.3.13",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0",
    "stripe": "^22.1.0"
  }
}
